# Runtime/app connection string. In Neon or Vercel Postgres this can be the pooled URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/pronosticos_mundial?schema=public"

# Optional but recommended for Prisma migrations on Neon/Vercel Postgres.
# Use the direct/non-pooled connection when your provider exposes one.
# Prisma config also accepts DATABASE_URL_UNPOOLED or POSTGRES_URL_NON_POOLING.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/pronosticos_mundial?schema=public"

# Required in production. Use a long random value.
SESSION_SECRET="replace-with-a-long-random-secret"

# Optional: used by `npm run db:seed` to set initial passwords for existing users.
# Leave empty if you prefer to set passwords with a controlled script later.
RAMIRO_INITIAL_PASSWORD=""
PEDRO_INITIAL_PASSWORD=""
