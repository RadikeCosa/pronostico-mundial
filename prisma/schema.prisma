generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MatchStage {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTERFINAL
  SEMIFINAL
  THIRD_PLACE
  FINAL
}

model Participant {
  id             String       @id @default(cuid())
  name           String       @unique
  slug           String       @unique
  normalizedName String       @unique
  passwordHash   String?
  isAdmin        Boolean      @default(false)
  active         Boolean      @default(true)
  predictions    Prediction[]
  resultsCreated MatchResult[] @relation("MatchResultCreatedBy")
  resultsUpdated MatchResult[] @relation("MatchResultUpdatedBy")
  lastLoginAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Team {
  id              String  @id @default(cuid())
  name            String  @unique
  code            String  @unique
  groupName       String?
  homeMatches     Match[] @relation("MatchHomeTeam")
  awayMatches     Match[] @relation("MatchAwayTeam")
}

model Match {
  id            String        @id @default(cuid())
  matchNumber   Int           @unique
  stage         MatchStage
  groupName     String?
  homeTeamName  String
  awayTeamName  String
  homeTeamId    String?
  awayTeamId    String?
  homeTeam      Team?         @relation("MatchHomeTeam", fields: [homeTeamId], references: [id])
  awayTeam      Team?         @relation("MatchAwayTeam", fields: [awayTeamId], references: [id])
  kickoffAt     DateTime
  venue         String?
  city          String?
  predictions   Prediction[]
  result        MatchResult?
}

model Prediction {
  id               String      @id @default(cuid())
  participantId    String
  matchId          String
  homeScore        Int
  awayScore        Int
  advancesTeamName String?
  participant      Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  match            Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([participantId, matchId])
}

model MatchResult {
  id                     String       @id @default(cuid())
  matchId                String       @unique
  homeScore              Int
  awayScore              Int
  advancesTeamName       String?
  createdByParticipantId String?
  updatedByParticipantId String?
  match                  Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdByParticipant   Participant? @relation("MatchResultCreatedBy", fields: [createdByParticipantId], references: [id], onDelete: SetNull)
  updatedByParticipant   Participant? @relation("MatchResultUpdatedBy", fields: [updatedByParticipantId], references: [id], onDelete: SetNull)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}
