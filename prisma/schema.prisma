generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MatchStage {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTERFINAL
  SEMIFINAL
  THIRD_PLACE
  FINAL
}

model Participant {
  id          String       @id @default(cuid())
  name        String       @unique
  active      Boolean      @default(true)
  predictions Prediction[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Team {
  id              String  @id @default(cuid())
  name            String  @unique
  code            String  @unique
  groupName       String?
  homeMatches     Match[] @relation("MatchHomeTeam")
  awayMatches     Match[] @relation("MatchAwayTeam")
}

model Match {
  id            String        @id @default(cuid())
  matchNumber   Int           @unique
  stage         MatchStage
  groupName     String?
  homeTeamName  String
  awayTeamName  String
  homeTeamId    String?
  awayTeamId    String?
  homeTeam      Team?         @relation("MatchHomeTeam", fields: [homeTeamId], references: [id])
  awayTeam      Team?         @relation("MatchAwayTeam", fields: [awayTeamId], references: [id])
  kickoffAt     DateTime
  venue         String?
  city          String?
  predictions   Prediction[]
  result        MatchResult?
}

model Prediction {
  id               String      @id @default(cuid())
  participantId    String
  matchId          String
  homeScore        Int
  awayScore        Int
  advancesTeamName String?
  participant      Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  match            Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([participantId, matchId])
}

model MatchResult {
  id               String   @id @default(cuid())
  matchId          String   @unique
  homeScore        Int
  awayScore        Int
  advancesTeamName String?
  match            Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
